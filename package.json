{
  "name": "discord-claude-code",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --env-file=.env.dev src/index.ts",
    "claude": "tsx --env-file=.env.claude --env-file=.env.dev src/index.ts",
    "qwen": "tsx --env-file=.env.qwen --env-file=.env.dev src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "chrono-node": "^2.9.0",
    "discord.js": "^14"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
